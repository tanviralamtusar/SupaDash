# SupaDash Studio Environment
# These values are used at build time and runtime.

# SupaDash Go API URL (internal Docker network)
SUPADASH_API_URL=http://supadash-api:8080

# Studio PG Meta URL (proxied through SupaDash API)
STUDIO_PG_META_URL=http://supadash-api:8080/platform/pg-meta

# Site configuration
NEXT_PUBLIC_SITE_TITLE=SupaDash
NEXT_PUBLIC_ENABLE_LOGS=true
NEXT_ANALYTICS_BACKEND_PROVIDER=postgres

# Hostname binding
HOSTNAME=0.0.0.0
PORT=3000
